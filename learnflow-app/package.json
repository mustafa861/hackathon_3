{
  "name": "learnflow-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "lint": "npm run lint:frontend",
    "lint:frontend": "cd frontend && npm run lint",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && pytest",
    "db:migrate": "cd frontend && npx prisma migrate dev",
    "db:generate": "cd frontend && npx prisma generate",
    "db:studio": "cd frontend && npx prisma studio",
    "db:seed": "cd frontend && npx prisma db seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
